# =============================================================================
# .env.example — SimpleRegister (Bóveda de Variables de Entorno)
# Protocolo secrets-guard: Este archivo SE COMMITEA. El archivo .env NO.
# Instrucción: Ejecutar `scripts/infra/setup_env.sh` para generar .env inicial.
# =============================================================================

# ---- Entorno de Ejecución ----
NODE_ENV=development
PORT=3000
NEXT_PUBLIC_APP_URL=http://localhost:3000
# URL del Frontend — usada para construir enlaces de verificación en los emails
# Referencia: PROJECT_spec.md §Plantilla de Link de Activación
APP_FRONTEND_URL=http://localhost:3000

# ---- Base de Datos (PostgreSQL 16) ----
# Hosts internos (dentro de Docker): usar nombre de servicio "db"
# Host local (sin Docker): usar "localhost"
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=simpleregister
POSTGRES_USER=sr_app
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# URL de conexión completa (Drizzle ORM)
DATABASE_URL=postgresql://sr_app:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/simpleregister

# ---- Caché y Seguridad (Redis 7) ----
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379

# ---- Seguridad de la Aplicación ----
# X-Health-Key: UUIDv4 generado automáticamente por setup_env.sh
# Regex de validación: /^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i
X_HEALTH_KEY=GENERATED_BY_SETUP_SCRIPT

# JWT para sesiones (mínimo 32 caracteres)
JWT_SECRET=CHANGE_ME_STRONG_JWT_SECRET_MIN_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ---- Rate Limiting (Spec: RNF7) ----
# Algoritmo Fixed Window: 10 req/min por IP para acceso público
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=10

# ---- Servicio de Email (SMTP) ----
# Estado validado a nivel de configuración (no se envía email real en health check)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=noreply@example.com
SMTP_PASS=CHANGE_ME_SMTP_PASSWORD
SMTP_FROM="SimpleRegister <noreply@example.com>"

# ---- Servicio de Captcha ----
# Estado validado a nivel de configuración (config_valid / error)
CAPTCHA_SITE_KEY=CHANGE_ME_CAPTCHA_SITE_KEY
CAPTCHA_SECRET_KEY=CHANGE_ME_CAPTCHA_SECRET_KEY

# ---- Observabilidad (Pino) ----
LOG_LEVEL=info
# Niveles válidos: trace | debug | info | warn | error | fatal | audit
